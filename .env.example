# BLACK-AND-BREW ERP — Environment Variables
# Copy to .env.local for local dev. Set the same keys in Vercel Dashboard → Production.
#
# Legend:
#   [PUBLIC]  = NEXT_PUBLIC_* (exposed to browser — never put secrets here)
#   [SECRET]  = server-only (Server Actions, API routes, cron)
#   [OPTION]  = feature works with fallbacks or is optional

# ─── SUPABASE [PUBLIC + SECRET] ───────────────────────────────────────────────
# Client: src/lib/supabase.ts, AI chat auth gate
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server: all Server Actions, readTableTool, schedule page, daily-report cron
# Never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ─── AUTH [SECRET] ────────────────────────────────────────────────────────────
# Full-access PIN (6 digits) — src/app/actions/auth.ts
APP_PIN=YOUR_APP_PIN

# Read-only PIN (6 digits) — src/app/actions/auth.ts via resolveReadOnlyPin()
# Required in production. Dev falls back to 111222 when unset.
APP_READ_ONLY_PIN=YOUR_READ_ONLY_PIN

# ─── BIOMETRIC LOGIN (Passkeys / WebAuthn) [OPTION] ───────────────────────────
# Usually auto-detected from request host. Set only if your public URL differs.
# Example: site runs at www.example.com but passkeys must use example.com
# WEBAUTHN_RP_ID=your-production-domain.com
# WEBAUTHN_ORIGIN=https://your-production-domain.com

# ─── STORE LOCATION [PUBLIC] ──────────────────────────────────────────────────
# Used by: /api/chat, market-insights, daily-report (weather section)
# /api/weather hardcodes 13.9312 / 100.6756 when unset — keep in sync with store
NEXT_PUBLIC_STORE_LAT=13.9312
NEXT_PUBLIC_STORE_LON=100.6756
# Branch id for Web Push broadcast scoping (default: main)
NEXT_PUBLIC_STORE_BRANCH_ID=main

# ─── AI [SECRET] ──────────────────────────────────────────────────────────────
# @ai-sdk/google (AI Chat /api/chat, Market Insights) — auto-reads this env name
GOOGLE_GENERATIVE_AI_API_KEY=YOUR_GOOGLE_GENERATIVE_AI_API_KEY

# AI internet search tool — src/app/actions/tools/search-tools.ts
TAVILY_API_KEY=YOUR_TAVILY_API_KEY

# ─── WEATHER [SECRET] ─────────────────────────────────────────────────────────
# /api/weather, daily-report cron, market-insights
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY

# ─── GOOGLE CALENDAR [SECRET] [OPTION] ────────────────────────────────────────
# Holiday sync — src/app/actions/holiday-actions.ts (schedule module)
GOOGLE_CALENDAR_API_KEY=YOUR_GOOGLE_CALENDAR_API_KEY

# ─── GOOGLE PLACES [SECRET] [OPTION] ──────────────────────────────────────────
# Market Insights v2 — nearby competitor cafés (src/app/actions/market-insights-places.ts)
# Feature skips silently when unset; no impact on other modules.
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY

# ─── LINE Messaging API [SECRET] [OPTION] ─────────────────────────────────────
# Manual admin notifications only — src/lib/line-notify.ts, sendLineNotification()
# Daily schedule cron uses Web Push (VAPID) instead — see below.
LINE_CHANNEL_ACCESS_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN
LINE_TARGET_RECIPIENT_ID=YOUR_LINE_USER_OR_GROUP_ID

# ─── CRON (cron-job.org) [SECRET] ─────────────────────────────────────────────
# Protects GET /api/daily-report — Authorization: Bearer <CRON_SECRET>
# Sends Web Push to all registered push_subscriptions (05:00 + 18:00 ICT)
# 05:00 ICT (today):     GET /api/daily-report
# 18:00 ICT (tomorrow):  GET /api/daily-report?schedule=tomorrow
CRON_SECRET=YOUR_SECURE_RANDOM_CRON_SECRET

# ─── WEB PUSH (inventory + daily schedule reports) [PUBLIC + SECRET] ──────────
# Generate: npx web-push generate-vapid-keys
# Public key is exposed to the browser for PushManager.subscribe()
NEXT_PUBLIC_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
# Contact for push service (mailto: or https:)
VAPID_SUBJECT=mailto:admin@your-domain.com
# Optional backup webhook auth — POST /api/push/webhook
PUSH_WEBHOOK_SECRET=YOUR_SECURE_RANDOM_PUSH_WEBHOOK_SECRET

# ─── NOTES ────────────────────────────────────────────────────────────────────
# 1. NEXT_PUBLIC_* vars are bundled for the browser — secrets must stay server-only.
# 2. .env.local is gitignored; use Vercel Dashboard for Production / Preview.
# 3. Removed from this file (not referenced in src/):
#    GOOGLE_API_KEY, GEMINI_API_KEY, LINE_CHANNEL_ID, READ_ONLY_PIN
