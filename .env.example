# BLACK-AND-BREW ERP — Environment Variables
# Copy to .env.local for local dev. Set the same keys in Vercel Dashboard → Production.
#
# Legend:
#   [PUBLIC]  = NEXT_PUBLIC_* (exposed to browser — never put secrets here)
#   [SECRET]  = server-only (Server Actions, API routes, cron)
#   [OPTION]  = feature works with fallbacks or is optional

# ─── SUPABASE [PUBLIC + SECRET] ───────────────────────────────────────────────
# Client: src/lib/supabase.ts, AI chat auth gate
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server: all Server Actions, readTableTool, schedule page, daily-report cron
# Never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ─── AUTH [SECRET] ────────────────────────────────────────────────────────────
# Full-access PIN (6 digits) — src/app/actions/auth.ts
APP_PIN=YOUR_APP_PIN

# Read-only PIN is hardcoded as 111222 in src/lib/auth-constants.ts (not an env var)

# ─── STORE LOCATION [PUBLIC] ──────────────────────────────────────────────────
# Used by: /api/chat, market-insights, daily-report (weather section)
# /api/weather hardcodes 13.9312 / 100.6756 when unset — keep in sync with store
NEXT_PUBLIC_STORE_LAT=13.9312
NEXT_PUBLIC_STORE_LON=100.6756

# ─── AI [SECRET] ──────────────────────────────────────────────────────────────
# @ai-sdk/google (AI Chat /api/chat, Market Insights) — auto-reads this env name
GOOGLE_GENERATIVE_AI_API_KEY=YOUR_GOOGLE_GENERATIVE_AI_API_KEY

# AI internet search tool — src/app/actions/tools/search-tools.ts
TAVILY_API_KEY=YOUR_TAVILY_API_KEY

# ─── WEATHER [SECRET] ─────────────────────────────────────────────────────────
# /api/weather, daily-report cron, market-insights
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY

# ─── GOOGLE CALENDAR [SECRET] [OPTION] ────────────────────────────────────────
# Holiday sync — src/app/actions/holiday-actions.ts (schedule module)
GOOGLE_CALENDAR_API_KEY=YOUR_GOOGLE_CALENDAR_API_KEY

# ─── LINE Messaging API [SECRET] ──────────────────────────────────────────────
# Push token — src/lib/line-notify.ts
LINE_CHANNEL_ACCESS_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN

# Recipient for daily cron — src/app/api/daily-report/route.ts
# LINE_GROUP_ID is checked first, then LINE_TARGET_RECIPIENT_ID
LINE_GROUP_ID=YOUR_LINE_GROUP_ID
LINE_TARGET_RECIPIENT_ID=YOUR_LINE_USER_OR_GROUP_ID

# ─── VERCEL CRON [SECRET] ─────────────────────────────────────────────────────
# Protects GET /api/daily-report — Authorization: Bearer <CRON_SECRET>
CRON_SECRET=YOUR_SECURE_RANDOM_CRON_SECRET

# ─── NOTES ────────────────────────────────────────────────────────────────────
# 1. NEXT_PUBLIC_* vars are bundled for the browser — secrets must stay server-only.
# 2. .env.local is gitignored; use Vercel Dashboard for Production / Preview.
# 3. Removed from this file (not referenced in src/):
#    GOOGLE_API_KEY, GEMINI_API_KEY, LINE_CHANNEL_ID, READ_ONLY_PIN
