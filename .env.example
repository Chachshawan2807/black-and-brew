# BLACK-AND-BREW ERP: Environment Variables Configuration
# Copy this file to .env.local and fill in the values.

# --- SUPABASE CONFIGURATION ---
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY
# ห้ามใส่ NEXT_PUBLIC_ นำหน้าเด็ดขาด เพื่อป้องกันไม่ให้คีย์หลุดไปที่ Browser
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# --- GOOGLE SERVICES & AI CONFIGURATION ---
GOOGLE_API_KEY=YOUR_GOOGLE_CLOUD_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GOOGLE_GENERATIVE_AI_API_KEY=YOUR_GOOGLE_GENERATIVE_AI_API_KEY
GOOGLE_CALENDAR_API_KEY=YOUR_GOOGLE_CALENDAR_API_KEY

# --- APPLICATION & EXTERNAL APIS ---
APP_PIN=YOUR_APP_PIN
TAVILY_API_KEY=YOUR_TAVILY_API_KEY
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY
NEXT_PUBLIC_STORE_LAT=YOUR_STORE_LAT
NEXT_PUBLIC_STORE_LON=YOUR_STORE_LON

# --- LINE Messaging API ---
LINE_CHANNEL_ACCESS_TOKEN="YOUR_LINE_CHANNEL_ACCESS_TOKEN"
LINE_CHANNEL_ID="YOUR_LINE_CHANNEL_ID"
LINE_TARGET_RECIPIENT_ID="YOUR_LINE_TARGET_RECIPIENT_ID"

# --- VERCEL CRON ---
CRON_SECRET="YOUR_SECURE_RANDOM_CRON_SECRET"

# 1. Variables prefixed with NEXT_PUBLIC_ are accessible to the browser.
# 2. Keep your real .env.local file out of version control (already in .gitignore).