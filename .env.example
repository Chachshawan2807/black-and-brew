# BLACK-AND-BREW ERP — Environment Variables
# Copy to .env.local for local dev. Set the same keys in Vercel Dashboard.
# Values here are placeholders only; never commit real secrets.
#
# Legend:
#   [PUBLIC] = NEXT_PUBLIC_* (exposed to browser)
#   [SECRET] = server-only

# ─── SUPABASE [PUBLIC + SECRET] ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Never prefix service-role keys with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ─── AI / GOOGLE [SECRET] ─────────────────────────────────────────────────────
# GOOGLE_GENERATIVE_AI_API_KEY is used by @ai-sdk/google.
# GOOGLE_API_KEY and GEMINI_API_KEY are kept in sync with local Gemini / AI SDK tooling.
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GOOGLE_GENERATIVE_AI_API_KEY=YOUR_GOOGLE_GENERATIVE_AI_API_KEY
GOOGLE_CALENDAR_API_KEY=YOUR_GOOGLE_CALENDAR_API_KEY
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY

# ─── AUTH [SECRET] ────────────────────────────────────────────────────────────
APP_PIN=YOUR_APP_PIN
APP_READ_ONLY_PIN=YOUR_READ_ONLY_PIN

# ─── AI SEARCH [SECRET] ───────────────────────────────────────────────────────
TAVILY_API_KEY=YOUR_TAVILY_API_KEY

# ─── STORE LOCATION [PUBLIC] ──────────────────────────────────────────────────
NEXT_PUBLIC_STORE_LAT=13.929692
NEXT_PUBLIC_STORE_LON=100.716933

# ─── SITE [PUBLIC] ────────────────────────────────────────────────────────────
# Canonical HTTPS origin — required for Apple Web Push VAPID subject (iOS PWA).
NEXT_PUBLIC_SITE_URL=https://your-production-domain.example

# ─── CRON + WEB PUSH [PUBLIC + SECRET] ────────────────────────────────────────
# Protects GET /api/daily-report — Authorization: Bearer <CRON_SECRET>
CRON_SECRET=YOUR_SECURE_RANDOM_CRON_SECRET
# Generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:admin@your-domain.com
# Prefer NEXT_PUBLIC_SITE_URL (https://your-domain) for iOS — Apple rejects some mailto subjects.
PUSH_WEBHOOK_SECRET=YOUR_SECURE_RANDOM_PUSH_WEBHOOK_SECRET

# ─── AgentSkillOS [.agent-skills/asos/.env — แยจาก Next.js] ─────────────────
# Copy .agent-skills/asos/.env.example → .agent-skills/asos/.env for orchestration.
# LLM_MODEL=openai/gpt-4o-mini
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=YOUR_KEY
