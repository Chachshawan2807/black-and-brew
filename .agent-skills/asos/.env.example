# AgentSkillOS LLM configuration (copy to .agent-skills/asos/.env)
# Separate from Next.js .env.local — never commit real keys.

# LLM (required for build / orchestration)
LLM_MODEL=openai/gpt-4o-mini
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-openrouter-api-key-here

# Embedding (optional — only when manager: vector)
EMBEDDING_MODEL=openai/text-embedding-3-large
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=your-openai-api-key-here

# ChromaDB persistent storage (optional)
CHROMA_PERSIST_DIR=data/vector_stores

# Fallback
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-api-key-here
